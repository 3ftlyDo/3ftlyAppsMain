{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile picture URL." },
        "role": { "type": "string", "enum": ["admin", "client"], "description": "The user's role in the application." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "AppSettings": {
      "title": "Application Settings",
      "description": "Global configuration for the application.",
      "type": "object",
      "properties": {
        "maintenanceMode": { "type": "boolean", "description": "Whether the app is in maintenance mode." },
        "allowRegistration": { "type": "boolean", "description": "Whether new users can register." },
        "debugLogging": { "type": "boolean", "description": "Whether debug logging is enabled." }
      },
      "required": ["maintenanceMode", "allowRegistration", "debugLogging"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Tracks administrative actions.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique log ID." },
        "action": { "type": "string", "description": "The action performed (e.g., 'DELETE_USER')." },
        "adminId": { "type": "string", "description": "UID of the admin who performed the action." },
        "adminEmail": { "type": "string", "description": "Email of the admin." },
        "targetId": { "type": "string", "description": "UID of the target user or resource." },
        "details": { "type": "string", "description": "Additional details about the action." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred." }
      },
      "required": ["action", "adminId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global application settings."
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "Collection of administrative audit logs."
    }
  }
}
